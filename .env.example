# ====================================
# QWESTINUM — Variables d'environnement
# ====================================
# Copie ce fichier en .env.local et remplis avec tes vraies valeurs
# .env.local n'est jamais commit (cf .gitignore)

# Supabase — récupéré dans Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — UNIQUEMENT côté serveur, ne jamais exposer côté client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# URL publique du site (utilisée pour les magic links et le SEO)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
